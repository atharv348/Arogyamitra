# ArogyaMitra Backend Environment Configuration
# Copy this file to .env and add your values

# Groq API Key for AI Features
# For project evaluation, working key is provided in README.md
GROQ_API_KEY=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

# JWT Secret Key
SECRET_KEY=arogyamitra-secret-key-change-in-production

# Database URL (SQLite by default, can be changed to PostgreSQL/MySQL)
DATABASE_URL=sqlite:///./arogyamitra.db

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT Token Expiry (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
